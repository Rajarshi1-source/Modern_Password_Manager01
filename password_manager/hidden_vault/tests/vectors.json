      "decoy_password": null,
      "real_payload_utf8": "{\"items\":[]}",
      "decoy_payload_utf8": null
    },
    {
      "id": "case-unicode-tier1",
      "tier": 1,
      "tier_bytes": 131072,
      "slot_payload_len": 60000,
      "real_password": "пароль-42",
