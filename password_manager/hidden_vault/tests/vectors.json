      "real_payload_utf8": "{\"items\":[{\"name\":\"バンク\",\"secret\":\"本物\"}]}",
      "decoy_payload_utf8": "{\"items\":[{\"name\":\"銀行\",\"secret\":\"偽物\"}]}"
