    "slot_count": 2,
    "kdf_id": 1,
    "kdf_time_cost": 3,
    "kdf_memory_kib": 65536,
    "kdf_parallelism": 1,
    "gcm_tag_len": 16,
    "nonce_len": 12,
    "outer_salt_len": 16,
    "slot_frame_magic": "48565331",
    "domain_tag_prefix": "48564c4f424c7631 2f 736c6f74"
  },
  "invariants": [
    "encode(...) -> blob of exactly tier_bytes bytes",
    "decode(blob, real_password).payload == real_payload",
    "decode(blob, decoy_password).payload == decoy_payload",
    "decode(blob, wrong_password) raises",
    "decode(blob, real_password).slot_index != decode(blob, decoy_password).slot_index",
    "changing only the real slot does not make the decoy slot decryptable by the real password"
